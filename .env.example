# Frontend (exposed to browser)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_APP_URL=https://jemput.neyobytes.com
VITE_API_URL=https://jemput.neyobytes.com/api
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# Backend (server only - see .env)
# LLM_*, STRIPE_*, SUPABASE_SERVICE_ROLE_KEY are server-side only
APP_URL=https://jemput.neyobytes.com
API_PORT=3002

# LLM (server-only)
LLM_PROVIDER=ollama-cloud
LLM_MODEL=kimi-k2.5:cloud
LLM_API_KEY=your_ollama_cloud_key_here
LLM_BASE_URL=https://ollama.com/v1
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
