# Frontend (exposed to browser)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_APP_URL=https://jemput.neyobytes.com
VITE_API_URL=https://jemput.neyobytes.com/api

# Backend (server only)
APP_URL=https://jemput.neyobytes.com
API_PORT=3002

# Supabase (server only)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# LLM (server-only)
LLM_PROVIDER=ollama-cloud
LLM_MODEL=kimi-k2.5:cloud
LLM_API_KEY=your_ollama_cloud_key_here
LLM_BASE_URL=https://ollama.com/v1
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# Stripe - Mode: "production" or "sandbox"
STRIPE_MODE=sandbox

# Stripe - Production keys
STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_your_key
STRIPE_LIVE_SECRET_KEY=sk_live_your_key
STRIPE_LIVE_WEBHOOK_SECRET=whsec_your_live_webhook_secret

# Stripe - Sandbox/Test keys
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_TEST_SECRET_KEY=sk_test_your_key
STRIPE_TEST_WEBHOOK_SECRET=whsec_your_test_webhook_secret
